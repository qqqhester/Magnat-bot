import random

def get_exp_next(current_level: int) -> int:
    """
    Расчет необходимого опыта для перехода на следующий уровень (Раздел 3.3 ТЗ).
    Защищено от отрицательного или нулевого уровня.
    """
    safe_level = max(1, current_level)
    return 100 * (safe_level ** 2)

def get_warehouse_capacity(warehouse_level: int) -> int:
    """
    Емкость склада в зависимости от его прокачки (Раздел 3.4 ТЗ).
    Защищено от критических значений.
    """
    safe_level = max(1, warehouse_level)
    return 50 * safe_level

def calculate_client_interval(reputation: int, ad_level: int) -> float:
    """
    Расчет интервала прихода покупателя в секундах.
    Базовый интервал — 300 сек. Репутация и реклама ускоряют поток.
    
    [ДОРАБОТКА]: Добавлены жесткие предохранители, чтобы при высоком авторитете
    и прокачанной рекламе таймер не уходил в минус или бесконечно малые значения.
    """
    base_interval = 300.0
    safe_reputation = max(0, reputation)
    safe_ad_level = max(1, ad_level)
    
    # Каждая единица репутации срезает 0.1 сек (но не дает опустить базовый интервал ниже 30 сек до применения рекламы)
    reputation_bonus = safe_reputation * 0.1
    reduced_base = max(30.0, base_interval - reputation_bonus)
    
    # Каждый ур. рекламы дает буст 15% (срезает время)
    ad_modifier = 1.0 - (safe_ad_level - 1) * 0.15
    # Реклама не может срезать время более чем на 85% от текущего значения
    ad_modifier = max(0.15, ad_modifier)
    
    interval = reduced_base * ad_modifier
    
    # Абсолютный игровой лимит: клиент не может приходить чаще, чем раз в 15 секунд
    return max(15.0, interval)

def get_final_price(is_auto: int, custom_price: float | None, base_price: float, showcase_level: int, demand_mod: float) -> float:
    """
    Расчет финальной розничной цены продажи товара с учетом прокачки витрины.
    """
    safe_base_price = max(0.01, base_price)
    safe_showcase_level = max(1, showcase_level)
    
    if is_auto == 1 or custom_price is None or custom_price <= 0:
        # Авто-цена: Базовая * Модификатор рынка * Буст витрины (+5% за уровень)
        showcase_boost = 1.0 + (safe_showcase_level - 1) * 0.05
        return round(safe_base_price * demand_mod * showcase_boost, 2)
        
    return round(custom_price, 2)

def calculate_raid_chance(security_level: int) -> int:
    """
    Шанс облавы силовиков при покупке контрабанды. 
    Уровень безопасности (охрана) снижает риск.
    """
    base_chance = 40  # Базовый риск 40%
    safe_security = max(1, security_level)
    
    reduced_chance = base_chance - (safe_security - 1) * 7
    
    # Минимальный риск облавы даже с топовой охраной — 5% (казино всегда в плюсе)
    return max(5, reduced_chance)

