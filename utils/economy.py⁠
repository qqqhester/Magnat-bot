def check_price_overhead(custom_price: float, base_price: float, demand_mod: float) -> dict:
    """
    Проверка пользовательской цены на предмет сверхприбыли (Оверпрайс).
    Если цена превышает рыночную (База * Модификатор спроса) более чем на 20%,
    функция сигнализирует о нарушении геймплейного баланса.
    
    Используется хэндлерами для начисления штрафов к авторитету/репутации.
    """
    market_price = base_price * demand_mod
    max_fair_price = market_price * 1.20  # +20% лимит
    
    is_overpriced = custom_price > max_fair_price
    percent_over = 0.0
    
    if is_overpriced:
        percent_over = ((custom_price - market_price) / market_price) * 100
        
    return {
        "is_overpriced": is_overpriced,
        "market_price": round(market_price, 2),
        "max_fair_price": round(max_fair_price, 2),
        "percent_over": round(percent_over, 1)
    }
